# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# PostgreSQL initialization (Docker)
POSTGRES_USER=rce
POSTGRES_PASSWORD=rce_secret
POSTGRES_DB=rce

# Async DSN — used by FastAPI (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://rce:rce_secret@postgres:5432/rce

# Sync DSN — used by Celery worker (psycopg2 driver)
SYNC_DATABASE_URL=postgresql+psycopg2://rce:rce_secret@postgres:5432/rce

# pgAdmin initialization (Docker)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# DB 0 — Celery broker + rate-limit counters + Pub/Sub
REDIS_URL=redis://redis:6379/0

# DB 1 — Celery result backend
REDIS_RESULT_URL=redis://redis:6379/1

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
S2S_JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET

# ---------------------------------------------------------------------------
# Sandbox
# ---------------------------------------------------------------------------
# Absolute path on the WORKER HOST where per-job directories are created.
# Must be accessible by both the worker process and Docker containers.
SANDBOX_BASE_DIR=/sandbox/jobs

# Absolute path on the Docker daemon host that backs /sandbox/jobs.
# Example (Windows): C:/Users/you/path/to/remote-code-execution-engine/docker/sandbox
HOST_SANDBOX_ROOT=

# ---------------------------------------------------------------------------
# WebSocket
# ---------------------------------------------------------------------------
WS_TIMEOUT_SEC=90
PING_INTERVAL_SEC=20

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
TOKEN_BUCKET_CAPACITY=1.0
TOKEN_BUCKET_REFILL_RATE=0.5
SLIDING_WINDOW_MAX=10
SLIDING_WINDOW_SEC=60

# ---------------------------------------------------------------------------
# Output caps (bytes)
# ---------------------------------------------------------------------------
STDOUT_CAP_BYTES=102400
STDERR_CAP_BYTES=4096
COMPILE_ERR_CAP_BYTES=4096


# ---------------------------------------------------------------------------
# Resend(Email service)
# ---------------------------------------------------------------------------
RESEND_API_KEY = 
RESEND_FROM_EMAIL = 