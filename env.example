# Copy this file to .env and fill in all values before running the application.
# Never commit the actual .env file to version control.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Async DSN — used by FastAPI (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://rce:rce_secret@localhost:5432/rce

# Sync DSN — used by Celery worker (psycopg2 driver)
SYNC_DATABASE_URL=postgresql+psycopg2://rce:rce_secret@localhost:5432/rce

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# DB 0 — Celery broker + rate-limit counters + Pub/Sub
REDIS_URL=redis://localhost:6379/0

# DB 1 — Celery result backend
REDIS_RESULT_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=86400

# Next.js -> FastAPI short-lived S2S JWT
S2S_JWT_SECRET=CHANGE_ME_S2S_STRONG_RANDOM_SECRET
S2S_JWT_ALGORITHM=HS256
S2S_JWT_ISSUER=nextjs-auth
S2S_JWT_AUDIENCE=fastapi-social

# Comma-separated origin allowlist for CORS
ALLOWED_ORIGINS=http://localhost:3000

# Email verification
VERIFICATION_TOKEN_TTL_SECONDS=86400
VERIFY_EMAIL_BASE_URL=http://localhost:3000/verify-email
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Sandbox
# ---------------------------------------------------------------------------
# Absolute path on the WORKER HOST where per-job directories are created.
# Must be accessible by both the worker process and Docker containers.
SANDBOX_BASE_DIR=/sandbox/jobs

# ---------------------------------------------------------------------------
# WebSocket
# ---------------------------------------------------------------------------
WS_TIMEOUT_SEC=90
PING_INTERVAL_SEC=20

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
TOKEN_BUCKET_CAPACITY=1.0
TOKEN_BUCKET_REFILL_RATE=0.5
SLIDING_WINDOW_MAX=10
SLIDING_WINDOW_SEC=60

# ---------------------------------------------------------------------------
# Output caps (bytes)
# ---------------------------------------------------------------------------
STDOUT_CAP_BYTES=102400
STDERR_CAP_BYTES=4096
COMPILE_ERR_CAP_BYTES=4096
